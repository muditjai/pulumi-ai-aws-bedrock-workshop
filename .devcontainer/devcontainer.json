{
  "name": "Pulumi AI AWS Bedrock Workshop",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",

  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "latest" },
    "ghcr.io/devcontainers/features/python:1": { "version": "latest" },
    "ghcr.io/devcontainers/features/github-cli:1": { "version": "latest" },
    "ghcr.io/dirien/devcontainer-features/opencode:0": { "version": "1.3.13" },
    "ghcr.io/dirien/devcontainer-feature-yaah/yaah:0": { "version": "0.3.3", "agent": "opencode" },
    "ghcr.io/dirien/devcontainer-feature-pulumi/pulumi:0": {}
  },

  "postCreateCommand": {
    "lsp-tools": "npm install -g prettier typescript typescript-language-server pyright",
    "uv": "curl -LsSf https://astral.sh/uv/install.sh | sh && echo 'export PATH=\"$HOME/.local/bin:$PATH\"' >> ~/.bashrc",
    "pip-deps": "pip install boto3 mcp ruff",
    "banner": "echo '[ -f \"${containerWorkspaceFolder}/.devcontainer/banner.sh\" ] && bash \"${containerWorkspaceFolder}/.devcontainer/banner.sh\"' >> ~/.bashrc"
  },

  "forwardPorts": [4096, 4097, 3000, 8000, 8080],
  "portsAttributes": {
    "4096": { "label": "OpenCode API" },
    "4097": { "label": "OpenCode Web" },
    "3000": { "label": "Dev Server" },
    "8000": { "label": "Dev Server Alt" },
    "8080": { "label": "Dev Server Alt 2" }
  },
  "otherPortsAttributes": { "onAutoForward": "silent" },

  "containerEnv": {
    "NODE_OPTIONS": "--dns-result-order=ipv4first"
  },

  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}",
    "PULUMI_ACCESS_TOKEN": "${localEnv:PULUMI_ACCESS_TOKEN}"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "pulumi.pulumi-vscode",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
